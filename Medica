  <div class="grid grid-cols-2 gap-3"><div><label class="lbl">Date of Birth</label><input id="pf-dob" type="date" class="inp" value="${p?.dateOfBirth||''}"></div><div><label class="lbl">Gender</label><select id="pf-gen" class="inp"><option value="">Select</option>${['Male','Female','Other'].map(gn=>`<option ${p?.gender===gn?'selected':''}>${gn}</option>`).join('')}</select></div></div>
