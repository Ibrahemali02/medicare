async function autoGenBill(apt){
  if(apt.status==='cancelled')return;
  const bills=await getBills();
  if(bills.find(b=>b.appointmentId===apt.id))return;
  const doctors=await getDoctors();
  const d=doctors.find(d=>d.id===apt.doctorId);if(!d)return;
  const total=parseFloat(d.consultationFee||0);
  await dbInsert('bills',{appointmentId:apt.id,total,status:'pending',date:new Date().toISOString().split('T')[0],notes:`Consultation — ${apt.appointmentDate} at ${apt.appointmentTime}`});
  clearCache('bills');
}

