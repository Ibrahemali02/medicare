-- 1. USERS TABLE
create table if not exists public.users (
  id          bigserial primary key,
  email       text unique not null,
  password    text not null,
  role        text not null default 'customer'
                check (role in ('admin','doctor','receptionist','customer')),
  first_name  text not null default '',
  last_name   text not null default '',
  phone       text,
  profile_image text,
  is_active   boolean not null default true,
  assigned_doctor_id bigint references public.users(id) on delete set null,
  created_at  timestamptz not null default now()
);

-- 2. PATIENTS TABLE
create table if not exists public.patients (
  id              bigserial primary key,
  user_id         bigint references public.users(id) on delete set null,
  first_name      text not null,
  last_name       text not null,
  email           text,
  phone           text,
  date_of_birth   date,
  gender          text,
  address         text,
  emergency_contact text,
  blood_type      text,
  allergies       text,
  profile_image   text,
  created_at      timestamptz not null default now()
);

-- 3. DOCTORS TABLE
create table if not exists public.doctors (
  id                bigint primary key references public.users(id) on delete cascade,
  specialization    text not null,
  consultation_fee  numeric(10,2) not null default 100,
  bio               text,
  address           text,
  created_at        timestamptz not null default now()
);

-- 4. APPOINTMENTS TABLE
create table if not exists public.appointments (
  id                bigserial primary key,
  patient_id        bigint references public.patients(id) on delete cascade,
  doctor_id         bigint references public.users(id) on delete cascade,
  appointment_date  date not null,
  appointment_time  text not null,
  status            text not null default 'scheduled'
                      check (status in ('scheduled','confirmed','completed','cancelled')),
  notes             text,
  created_by        bigint references public.users(id) on delete set null,
  created_at        timestamptz not null default now()
);

-- 5. RECORDS TABLE
create table if not exists public.records (
  id           bigserial primary key,
  patient_id   bigint references public.patients(id) on delete cascade,
  doctor_id    bigint references public.users(id) on delete set null,
  record_date  date not null,
  diagnosis    text not null,
  treatment    text,
  prescription text,
  condition    text check (condition in ('improved','stable','worsened')),
  created_at   timestamptz not null default now()
);

-- 6. LABS TABLE
create table if not exists public.labs (
  id           bigserial primary key,
  patient_id   bigint references public.patients(id) on delete cascade,
  doctor_id    bigint references public.users(id) on delete set null,
  test_name    text not null,
  ordered_date date not null,
  result       text,
  status       text not null default 'pending'
                 check (status in ('pending','completed')),
  created_at   timestamptz not null default now()
);

-- 7. BILLS TABLE
create table if not exists public.bills (
  id              bigserial primary key,
  appointment_id  bigint references public.appointments(id) on delete cascade,
  total           numeric(10,2) not null default 0,
  status          text not null default 'pending'
                    check (status in ('pending','paid')),
  date            date not null default current_date,
  notes           text,
  created_at      timestamptz not null default now()
);

-- 8. NOTIFICATIONS TABLE
create table if not exists public.notifs (
  id         bigserial primary key,
  user_id    bigint references public.users(id) on delete cascade,
  title      text,
  message    text,
  type       text default 'info',
  is_read    boolean not null default false,
  created_at timestamptz not null default now()
);

-- 9. AUDIT LOG TABLE
create table if not exists public.audit_log (
  id         bigserial primary key,
  user_id    bigint,
  user_name  text,
  role       text,
  action     text,
  detail     text,
  time       timestamptz not null default now()
);

-- 10. CONFIG TABLE
create table if not exists public.cfg (
  id          bigserial primary key,
  clinic_name text not null default 'MediCare Pro',
  appt_dur    integer not null default 30,
  currency    text not null default '$',
  notifs      boolean not null default true,
  updated_at  timestamptz not null default now()
);

