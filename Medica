// ── AUTH ──
async function doSignup(){
  const btn=sel('signup-btn');
  const imgData=g('s-img-data');
  if(!imgData){toast('Please upload a profile photo','error');return;}
  const fn=g('s-fn'),ln=g('s-ln'),em=g('s-em'),ph=g('s-ph'),pw=g('s-pw'),cpw=g('s-cpw');
  if(!fn||!ln||!em||!ph||!pw){toast('Please fill all required fields','error');return;}
  if(!checked('s-agree')){toast('Please agree to Terms & Conditions','error');return;}
  if(pw!==cpw){toast('Passwords do not match','error');return;}
  if(pw.length<6){toast('Password must be at least 6 characters','error');return;}
  const emailRegex=/^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if(!emailRegex.test(em)){toast('Please enter a valid email address','error');return;}

  if(btn){btn.disabled=true;btn.innerHTML='<i class="fas fa-spinner fa-spin mr-2"></i>Creating account…';}
  try{
    // Check if email exists
    const{data:existingRows,error:checkErr}=await sb.from('users').select('id').eq('email',em);
    if(checkErr){toast('Database error: '+checkErr.message,'error');return;}
    if(existingRows&&existingRows.length>0){toast('Email already registered. Please sign in.','error');return;}

    // Insert user
    const{data:nu,error:uErr}=await sb.from('users').insert({
      email:em,password:hashPw(pw),role:'customer',
      first_name:fn,last_name:ln,phone:ph,
      is_active:true,profile_image:imgData
    }).select().single();
    if(uErr||!nu){toast('Registration failed: '+(uErr?.message||'Unknown error'),'error');return;}

    // Insert patient profile
    const{error:pErr}=await sb.from('patients').insert({
      user_id:nu.id,first_name:fn,last_name:ln,
      email:em,phone:ph,profile_image:imgData
    });
    if(pErr){console.warn('Patient profile error:',pErr.message);}

    clearCache();
    toast('Account created successfully! Please sign in.','success');
    // Clear form
    ['s-fn','s-ln','s-em','s-ph','s-pw','s-cpw'].forEach(id=>{const e=sel(id);if(e)e.value='';});
    const di=sel('s-img-data');if(di)di.value='';
    const dp=sel('s-img-prev');if(dp)dp.innerHTML='<i class="fas fa-camera text-3xl text-gray-300 block mb-2"></i><p class="text-sm text-gray-500 font-medium">Click to upload profile photo</p>';
    const db=sel('s-img-box');if(db)db.classList.remove('has-img');
    const ca=sel('s-agree');if(ca)ca.checked=false;
    showPage('pg-login');
  }finally{
    if(btn){btn.disabled=false;btn.innerHTML='<i class="fas fa-user-plus mr-2"></i>Create Patient Account';}
  }
}

async function doLogin(){
  const btn=sel('login-btn');
  const em=g('l-em'),pw=g('l-pw');
  if(!em||!pw){toast('Enter email and password','error');return;}
  if(btn){btn.disabled=true;btn.innerHTML='<i class="fas fa-spinner fa-spin mr-2"></i>Signing in…';}
  try{
    const{data:rows,error}=await sb.from('users').select('*').eq('email',em);
    if(error){toast('Database error: '+error.message,'error');return;}
    if(!rows||rows.length===0){toast('No account found with that email','error');return;}
    const users=snakeToCamel(rows);
    const user=users.find(u=>u.isActive&&checkPw(u.password,pw));
    if(user){
      CU=user;
      try{sessionStorage.setItem('hms_cu',JSON.stringify(user));}catch(e){window._hcu=user;}
      clearCache();
      await launchApp();
      toast(`Welcome back, ${user.firstName}! 👋`,'success');
    }else{
      const inactive=users.find(u=>!u.isActive&&checkPw(u.password,pw));
      toast(inactive?'Your account is inactive. Contact the administrator.':'Incorrect password.','error');
    }
  }finally{
    if(btn){btn.disabled=false;btn.innerHTML='<i class="fas fa-sign-in-alt mr-2"></i>Sign In';}
  }
}

