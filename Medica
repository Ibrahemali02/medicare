async function refreshSlots(){
  const docIdRaw=g('af-doc')||(CU.role==='doctor'?String(CU.id):'');
  const docId=parseInt(docIdRaw),date=g('af-date'),te=sel('af-time'),info=sel('af-info');
  if(!te||!info)return;
  if(!docId||!date){info.textContent='Select doctor & date to view availability';return;}
  const booked=await bookedSlots(docId,date);
  const avail=timeSlots().filter(t=>!booked.includes(t)),cur2=te.value;
  te.innerHTML='<option value="">Select time</option>'+avail.map(t=>`<option value="${t}" ${t===cur2?'selected':''}>✅ ${t}</option>`).join('')+booked.map(t=>`<option disabled>❌ ${t} (Booked)</option>`).join('');
  info.innerHTML=`${avail.length} slots available · <span class="text-red-500">${booked.length} booked</span>`;
}

async function saveApt(){
  const docIdRaw=g('af-doc')||(CU.role==='doctor'?String(CU.id):'');
  const docId=parseInt(docIdRaw);
  if(!docId){toast('Select a doctor','error');return;}
  let ptId;
  if(CU.role==='customer'){const cp=await getCurPt();if(!cp){toast('Patient profile not found','error');return;}ptId=cp.id;}
  else{ptId=parseInt(g('af-pt'));if(!ptId){toast('Select a patient','error');return;}}
  const date=g('af-date'),time=g('af-time'),notes=g('af-notes');
  if(!date||!time){toast('Fill all required fields','error');return;}
  const booked=await bookedSlots(docId,date);
  if(booked.includes(time)){toast('This time slot is already booked!','error');return;}
  const apt=await dbInsert('appointments',{patientId:ptId,doctorId:docId,appointmentDate:date,appointmentTime:time,status:'scheduled',notes,createdBy:CU.id});
  if(!apt){toast('Failed to book appointment','error');return;}
  await autoGenBill(apt);
  clearCache('apts','bills');
  toast('Appointment booked! Bill auto-generated.','success');
  closeModal();loadPage(CU.role==='customer'?'my-apts':'appointments');
}

