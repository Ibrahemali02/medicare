// ═══════════════════ ANALYTICS ═══════════════════
async function pgAnalytics(){
  if(CU.role==='customer'||CU.role==='receptionist')return deny();
  const[users,doctors,patients,apts,bills,labs,records]=await Promise.all([getUsers(),getDoctors(),getPatients(),getAppointments(),getBills(),getLabs(),getRecords()]);
  const isAdmin=CU.role==='admin';
  let recs=records,filteredApts=apts,filteredLabs=labs,filteredPts=patients;
  if(CU.role==='doctor'){recs=records.filter(r=>r.doctorId===CU.id);filteredApts=apts.filter(a=>a.doctorId===CU.id);filteredLabs=labs.filter(l=>l.doctorId===CU.id);const ptIds=[...new Set(filteredApts.map(a=>a.patientId))];filteredPts=patients.filter(p=>ptIds.includes(p.id));}
  const today=new Date().toISOString().split('T')[0];
  const cm=new Date().getMonth(),cy=new Date().getFullYear();
  const rev=bills.filter(b=>{if(!isAdmin&&!filteredApts.find(a=>a.id===b.appointmentId))return false;const d=new Date(b.date);return d.getMonth()===cm&&d.getFullYear()===cy&&b.status==='paid';}).reduce((s,b)=>s+parseFloat(b.total||0),0);
  const imp={i:recs.filter(r=>r.condition==='improved').length,s:recs.filter(r=>r.condition==='stable').length,w:recs.filter(r=>r.condition==='worsened').length,t:recs.length};
  const ast={sc:filteredApts.filter(a=>a.status==='scheduled').length,co:filteredApts.filter(a=>a.status==='confirmed').length,cp:filteredApts.filter(a=>a.status==='completed').length,ca:filteredApts.filter(a=>a.status==='cancelled').length};
  const todayApts=filteredApts.filter(a=>a.appointmentDate===today);
  const c=cur();
  const bar=(l,cnt,tot,col)=>{const p=tot?Math.round(cnt/tot*100):0;return`<div><div class="flex justify-between text-xs mb-1"><span class="font-semibold capitalize text-gray-700">${l}</span><span class="text-gray-500">${cnt} (${p}%)</span></div><div class="prog"><div class="prog-b ${col}" style="width:${p}%"></div></div></div>`;};
  const docSection=isAdmin?`<div class="card p-5"><div class="flex items-center gap-2 mb-4"><i class="fas fa-user-md text-blue-500"></i><h2 class="font-bold text-sm">Per-Doctor Analytics</h2></div><div class="overflow-x-auto"><table class="w-full"><thead><tr><th class="th">Doctor</th><th class="th">Specialization</th><th class="th">Patients</th><th class="th">Appointments</th><th class="th">Revenue</th></tr></thead><tbody>${doctors.map(d=>{const u=users.find(u=>u.id===d.id);if(!u)return'';const dApts=apts.filter(a=>a.doctorId===d.id);const dPts=[...new Set(dApts.map(a=>a.patientId))].length;const dRev=bills.filter(b=>dApts.map(a=>a.id).includes(b.appointmentId)&&b.status==='paid').reduce((s,b)=>s+parseFloat(b.total||0),0);return`<tr class="trow"><td class="td"><div class="flex items-center gap-2">${ava(u.profileImage,u.firstName)}<p class="text-xs font-bold">Dr. ${u.firstName} ${u.lastName}</p></div></td><td class="td text-xs"><span class="badge b-blue">${d.specialization}</span></td><td class="td text-xs font-bold text-blue-700">${dPts}</td><td class="td text-xs font-bold text-green-700">${dApts.length}</td><td class="td text-xs font-bold text-amber-700">${c}${dRev.toFixed(2)}</td></tr>`;}).join('')||'<tr><td colspan="5" class="td text-center text-gray-400 py-6">No doctors</td></tr>'}</tbody></table></div></div>`:'';
  return`<div class="space-y-5">
  <div class="flex items-center justify-between flex-wrap gap-3"><div class="flex items-center gap-2"><i class="fas fa-chart-line text-blue-500 text-lg"></i><h1 class="text-xl font-bold">${isAdmin?'System':'My'} Analytics</h1></div><button onclick="loadPage('reports')" class="btn bo text-xs"><i class="fas fa-file-alt mr-1"></i>Full Reports</button></div>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">${statCard('Patients',filteredPts.length,'fas fa-users','bg-blue-50 text-blue-600')}${statCard("Today's Apts",todayApts.length,'fas fa-calendar-check','bg-green-50 text-green-600')}${statCard('Monthly Revenue',c+rev.toFixed(2),'fas fa-dollar-sign','bg-amber-50 text-amber-600')}${statCard('Lab Tests',filteredLabs.length,'fas fa-flask','bg-purple-50 text-purple-600')}</div>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <div class="card p-5"><div class="flex items-center gap-2 mb-4"><i class="fas fa-heartbeat text-red-500"></i><h2 class="font-bold text-sm">Patient Condition Outcomes</h2></div><div class="space-y-4">${bar('Improved',imp.i,imp.t,'bg-green-500')}${bar('Stable',imp.s,imp.t,'bg-amber-500')}${bar('Worsened',imp.w,imp.t,'bg-red-500')}</div><div class="grid grid-cols-3 gap-3 mt-5"><div class="text-center bg-green-50 rounded-xl p-3"><p class="text-2xl font-bold text-green-700">${imp.i}</p><p class="text-xs text-green-600">Improved</p></div><div class="text-center bg-amber-50 rounded-xl p-3"><p class="text-2xl font-bold text-amber-700">${imp.s}</p><p class="text-xs text-amber-600">Stable</p></div><div class="text-center bg-red-50 rounded-xl p-3"><p class="text-2xl font-bold text-red-700">${imp.w}</p><p class="text-xs text-red-600">Worsened</p></div></div></div>
    <div class="card p-5"><div class="flex items-center gap-2 mb-4"><i class="fas fa-calendar-check text-blue-500"></i><h2 class="font-bold text-sm">Appointment Breakdown</h2></div><div class="grid grid-cols-2 gap-3"><div class="bg-blue-50 rounded-xl p-4 text-center"><i class="fas fa-clock text-blue-500 text-xl block mb-1"></i><p class="text-2xl font-bold text-blue-700">${ast.sc}</p><p class="text-xs text-blue-600">Scheduled</p></div><div class="bg-teal-50 rounded-xl p-4 text-center"><i class="fas fa-check-circle text-teal-500 text-xl block mb-1"></i><p class="text-2xl font-bold text-teal-700">${ast.co}</p><p class="text-xs text-teal-600">Confirmed</p></div><div class="bg-gray-50 rounded-xl p-4 text-center"><i class="fas fa-check text-gray-500 text-xl block mb-1"></i><p class="text-2xl font-bold text-gray-700">${ast.cp}</p><p class="text-xs text-gray-600">Completed</p></div><div class="bg-red-50 rounded-xl p-4 text-center"><i class="fas fa-times text-red-500 text-xl block mb-1"></i><p class="text-2xl font-bold text-red-700">${ast.ca}</p><p class="text-xs text-red-600">Cancelled</p></div></div></div>
  </div>
  <div class="card p-5"><div class="flex items-center gap-2 mb-4"><i class="fas fa-dollar-sign text-green-500"></i><h2 class="font-bold text-sm">Revenue — Last 6 Months</h2></div><div class="grid grid-cols-3 md:grid-cols-6 gap-3">${Array.from({length:6},(_,i)=>{const m=new Date();m.setMonth(m.getMonth()-i);const mn=m.getMonth(),my=m.getFullYear();const ids=filteredApts.map(a=>a.id);const r=bills.filter(b=>{const d=new Date(b.date);return(isAdmin||ids.includes(b.appointmentId))&&d.getMonth()===mn&&d.getFullYear()===my&&b.status==='paid';}).reduce((s,b)=>s+parseFloat(b.total||0),0);return`<div class="bg-gradient-to-b from-blue-50 to-indigo-50 rounded-xl p-3 text-center border border-blue-100"><p class="text-xs text-gray-500 font-medium">${m.toLocaleDateString('en-US',{month:'short'})}</p><p class="text-lg font-bold text-indigo-700 mt-1">${c}${r.toFixed(0)}</p></div>`;}).join('')}</div></div>
  ${docSection}</div>`;
}

