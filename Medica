async function saveCfg(){
  const newCfg={clinicName:g('cfg-name')||'MediCare Pro',apptDur:parseInt(g('cfg-dur'))||30,currency:g('cfg-cur')||'$',notifs:true};
  if(_cfg.id){await dbUpdate('cfg',_cfg.id,newCfg);}else{const row=await dbInsert('cfg',newCfg);if(row)newCfg.id=row.id;}
  _cfg={..._cfg,...newCfg};delete cache.cfg;buildNav();toast('Configuration saved!','success');
}

async function changeMyPw(){
  const cur2=g('cp-cur'),nw=g('cp-new'),con=g('cp-con');
  if(nw!==con){toast('Passwords do not match','error');return;}
  if(nw.length<6){toast('Min 6 characters','error');return;}
  const users=await getUsers();const admin=users.find(u=>u.id===CU.id);
  if(!admin||!checkPw(admin.password,cur2)){toast('Current password incorrect','error');return;}
  await dbUpdate('users',CU.id,{password:hashPw(nw)});clearCache('users');toast('Password changed!','success');
  ['cp-cur','cp-new','cp-con'].forEach(id=>{const e=sel(id);if(e)e.value='';});
}

async function toggleUserSt(id){
  const users=await getUsers();const u=users.find(u=>u.id===id);
  if(u&&u.id!==CU.id){await dbUpdate('users',id,{isActive:!u.isActive});clearCache('users');toast(`User ${!u.isActive?'enabled':'disabled'}`,'success');loadPage('settings');}
}

// ═══════════════════ PDF ENGINE ═══════════════════
function genPDF(html,fname){
  const d=document.createElement('div');d.className='pdf-w';d.style.cssText='position:fixed;left:-9999px;top:0;z-index:-1;background:#fff;';d.innerHTML=html;document.body.appendChild(d);
  html2canvas(d,{scale:2,useCORS:true,logging:false}).then(canvas=>{
    document.body.removeChild(d);
    const{jsPDF}=window.jspdf,pdf=new jsPDF('p','mm','a4');
    const w=210,ph=297,ih=(canvas.height*w)/canvas.width;let hl=ih,pos=0;
    pdf.addImage(canvas.toDataURL('image/png'),'PNG',0,pos,w,ih);hl-=ph;
    while(hl>=0){pos=hl-ih;pdf.addPage();pdf.addImage(canvas.toDataURL('image/png'),'PNG',0,pos,w,ih);hl-=ph;}
    pdf.save(fname);toast('PDF downloaded!','success');
  }).catch(err=>{if(document.body.contains(d))document.body.removeChild(d);toast('PDF error: '+err.message,'error');});
}
const cn2=()=>_cfg.clinicName||'MediCare Pro';
const c3=()=>_cfg.currency||'$';
const pHdr=sub=>`<div style="border-bottom:2px solid #0a1628;padding-bottom:14px;margin-bottom:18px;display:flex;justify-content:space-between;align-items:flex-start;"><div><div style="font-size:22px;font-weight:bold;color:#0a1628;">${cn2()}</div><div style="color:#64748b;font-size:13px;margin-top:4px;">${sub}</div></div><div style="text-align:right;font-size:11px;color:#94a3b8;">Generated: ${new Date().toLocaleString()}</div></div>`;
const pSec=(t,rows)=>`<div style="margin-bottom:16px;"><div style="font-size:13px;font-weight:bold;color:#0a1628;border-bottom:1px solid #e2e8f0;padding-bottom:5px;margin-bottom:8px;">${t}</div><table class="pdf-t">${rows}</table></div>`;
const pRow=(l,v)=>`<tr><td style="width:35%;background:#f8fafc;font-weight:bold;">${l}</td><td>${v||'N/A'}</td></tr>`;

async function dlBillPDF(id){
  const[bills,appointments,patients]=await Promise.all([getBills(),getAppointments(),getPatients()]);
  const b=bills.find(b=>b.id===id);if(!b){toast('Bill not found','error');return;}
  const apt=appointments.find(a=>a.id===b.appointmentId);const p=apt?patients.find(p=>p.id===apt.patientId):null;const c=c3();
  genPDF(`${pHdr('Medical Bill — Official Receipt')}${pSec('Bill Information',pRow('Bill #',b.id)+pRow('Date',b.date)+pRow('Status',b.status.toUpperCase())+pRow('Notes',b.notes))}${pSec('Patient Information',pRow('Name',p?p.firstName+' '+p.lastName:'N/A')+pRow('Phone',p?.phone)+pRow('Email',p?.email))}${pSec('Charges',pRow('Total',c+parseFloat(b.total||0).toFixed(2)))}${b.status==='paid'?`<div style="background:#d1fae5;border:1px solid #a7f3d0;border-radius:8px;padding:10px;font-size:12px;"><strong style="color:#065f46;">✓ PAYMENT CONFIRMED</strong></div>`:''}`,`Bill_#${b.id}_${b.date}.pdf`);
}

async function dlRecPDF(id){
  const[records,patients,users,doctors]=await Promise.all([getRecords(),getPatients(),getUsers(),getDoctors()]);
  const r=records.find(r=>r.id===id);if(!r){toast('Record not found','error');return;}
  const p=patients.find(p=>p.id===r.patientId),du=users.find(u=>u.id===r.doctorId),d=doctors.find(d=>d.id===r.doctorId);
  genPDF(`${pHdr('Medical Record — Confidential')}${pSec('Patient Information',pRow('Full Name',p?p.firstName+' '+p.lastName:'N/A')+pRow('Date of Birth',p?.dateOfBirth)+pRow('Gender',p?.gender)+pRow('Blood Type',p?.bloodType)+pRow('Allergies',p?.allergies))}${pSec('Clinical Information',pRow('Visit Date',fmtDate(r.recordDate))+pRow('Doctor',du?'Dr. '+du.firstName+' '+du.lastName:'N/A')+pRow('Specialization',d?.specialization)+pRow('Diagnosis',r.diagnosis)+pRow('Treatment',r.treatment)+pRow('Prescription',r.prescription)+pRow('Condition',r.condition?r.condition.toUpperCase():''))}`,`MedRecord_${p?.lastName||'Patient'}_${r.recordDate}.pdf`);
}

async function dlLabPDF(id){
  const[labs,patients,users,doctors]=await Promise.all([getLabs(),getPatients(),getUsers(),getDoctors()]);
  const l=labs.find(l=>l.id===id);if(!l){toast('Lab test not found','error');return;}
  const p=patients.find(p=>p.id===l.patientId),du=users.find(u=>u.id===l.doctorId),d=doctors.find(d=>d.id===l.doctorId);
  genPDF(`${pHdr('Laboratory Test Report')}${pSec('Patient Information',pRow('Full Name',p?p.firstName+' '+p.lastName:'N/A')+pRow('Date of Birth',p?.dateOfBirth)+pRow('Blood Type',p?.bloodType))}${pSec('Test Details',pRow('Test Name',l.testName)+pRow('Date',fmtDate(l.orderedDate))+pRow('Ordered By',du?'Dr. '+du.firstName+' '+du.lastName:'N/A')+pRow('Status',l.status.toUpperCase()))}${pSec('Results',`<tr><td style="padding:12px;">${l.result||'<em>Pending — results will be updated by your doctor.</em>'}</td></tr>`)}`,`LabReport_${p?.lastName||'Patient'}_${(l.testName||'test').replace(/\s+/g,'_')}_${l.orderedDate}.pdf`);
}
