  <div><label class="lbl">Emergency Contact</label><input id="pf-ec" class="inp" value="${p?.emergencyContact||''}"></div>
  <div class="grid grid-cols-2 gap-3"><div><label class="lbl">Blood Type</label><select id="pf-bt" class="inp"><option value="">Select</option>${['A+','A-','B+','B-','AB+','AB-','O+','O-'].map(t=>`<option ${p?.bloodType===t?'selected':''}>${t}</option>`).join('')}</select></div><div><label class="lbl">Allergies</label><input id="pf-all" class="inp" value="${p?.allergies||''}"></div></div>
  <div class="flex justify-end gap-2 pt-2"><button onclick="closeModal()" class="btn bo text-xs">Cancel</button><button onclick="savePt()" class="btn bp text-xs"><i class="fas fa-save mr-1"></i>${p?'Update':'Create'}</button></div></div>`,'fas fa-user-plus');
