async function savePt(){
  const fn=g('pf-fn'),ln=g('pf-ln');
  if(!fn||!ln){toast('Fill required fields','error');return;}
  const imgData=g('pt_img_data');
  if(!EID.pt&&!imgData){toast('Profile photo is required','error');return;}
  const data={firstName:fn,lastName:ln,email:g('pf-em'),phone:g('pf-ph'),dateOfBirth:g('pf-dob')||null,gender:g('pf-gen'),address:g('pf-adr'),emergencyContact:g('pf-ec'),bloodType:g('pf-bt'),allergies:g('pf-all'),...(imgData?{profileImage:imgData}:{})};
  if(EID.pt){await dbUpdate('patients',EID.pt,data);toast('Patient updated','success');}
  else{await dbInsert('patients',data);toast('Patient created','success');}
  clearCache('patients');
  await writeAudit('PATIENT_SAVE',`${EID.pt?'Updated':'Created'} patient: ${fn} ${ln}`);
  closeModal();loadPage('patients');
}

async function delPt(id){
  if(!confirm('Delete this patient?'))return;
  await dbDelete('patients',id);
  clearCache('patients','apts','records','bills','labs');
  await writeAudit('PATIENT_DELETE',`Deleted patient #${id}`);
  toast('Patient deleted','success');loadPage('patients');
}

