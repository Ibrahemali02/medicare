function timeSlots(){const s=[];for(let h=8;h<=18;h++)for(let m=0;m<60;m+=30)s.push(`${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`);return s;}

async function bookedSlots(docId,date,excId=null){
