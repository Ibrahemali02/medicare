async function genBillingReport(){
  const from=g('br-from'),to=g('br-to'),st=g('br-st')||'all';
  let bills=await getBills();
  if(CU.role==='doctor'){const ids=(await getAppointments()).filter(a=>a.doctorId===CU.id).map(a=>a.id);bills=bills.filter(b=>ids.includes(b.appointmentId));}
  if(from)bills=bills.filter(b=>b.date>=from);if(to)bills=bills.filter(b=>b.date<=to);if(st!=='all')bills=bills.filter(b=>b.status===st);
  const c=cur(),el=sel('billing-rep-result');if(!el)return;
  const[apts,pts]=await Promise.all([getAppointments(),getPatients()]);
  el.innerHTML=`<div class="space-y-4"><div class="grid grid-cols-3 gap-4">${statCard('Total Bills',bills.length,'fas fa-receipt','bg-blue-50 text-blue-600')}${statCard('Revenue',c+bills.filter(b=>b.status==='paid').reduce((s,b)=>s+parseFloat(b.total||0),0).toFixed(2),'fas fa-dollar-sign','bg-green-50 text-green-600')}${statCard('Outstanding',c+bills.filter(b=>b.status==='pending').reduce((s,b)=>s+parseFloat(b.total||0),0).toFixed(2),'fas fa-clock','bg-amber-50 text-amber-600')}</div><div class="card overflow-hidden"><div class="overflow-x-auto"><table class="w-full"><thead><tr><th class="th">Bill #</th><th class="th">Patient</th><th class="th">Date</th><th class="th">Amount</th><th class="th">Status</th></tr></thead><tbody>${bills.map(b=>{const apt=apts.find(a=>a.id===b.appointmentId);const p=apt?pts.find(p=>p.id===apt.patientId):null;return`<tr class="trow"><td class="td text-xs font-bold">#${b.id}</td><td class="td text-xs">${p?p.firstName+' '+p.lastName:'Unknown'}</td><td class="td text-xs">${b.date}</td><td class="td text-xs font-bold">${c}${parseFloat(b.total||0).toFixed(2)}</td><td class="td">${billBadge(b.status)}</td></tr>`;}).join('')||'<tr><td colspan="5" class="td text-center text-gray-400 py-8">No bills found</td></tr>'}</tbody></table></div></div></div>`;
}

