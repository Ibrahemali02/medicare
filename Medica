// ── Image Upload ──
function handleImgUpload(event,boxId,dataId,prevId){
  const file=event.target.files[0];if(!file)return;
  if(file.size>3*1024*1024){toast('Image must be under 3MB','error');event.target.value='';return;}
  b64f(file,data=>{
    const box=sel(boxId),dataEl=sel(dataId),prev=sel(prevId);
    if(dataEl)dataEl.value=data;
    if(prev)prev.innerHTML=`<img src="${data}" class="img-preview"><p class="text-xs text-green-600 font-semibold"><i class="fas fa-check-circle mr-1"></i>Photo uploaded</p><p class="text-xs text-gray-400 mt-1">Click to change</p>`;
    if(box)box.classList.add('has-img');
  });
}

