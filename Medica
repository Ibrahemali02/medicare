  const myAptIds=myApts.map(a=>a.id);
  const myBillsFull=bills.filter(b=>myAptIds.includes(b.appointmentId));
  const upcoming=myApts.filter(a=>a.appointmentDate>=today&&a.status!=='cancelled').sort((a,b)=>a.appointmentDate.localeCompare(b.appointmentDate));
  const pending=myBillsFull.filter(b=>b.status==='pending');
  const pendingLabs=myLabs.filter(l=>l.status==='pending');
  const users=await getUsers(),doctors=await getDoctors();
  const c=cur();
  return`<div class="space-y-5">
  <div class="flex items-center justify-between flex-wrap gap-2"><div><h1 class="text-xl font-bold text-gray-900">Good day, ${CU.firstName}! <span class="text-2xl">👋</span></h1><p class="text-gray-400 text-sm">Your personal health overview</p></div><button onclick="loadPage('book-apt')" class="btn bp text-xs"><i class="fas fa-calendar-plus mr-1"></i>Book Appointment</button></div>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">${statCard('Upcoming Visits',upcoming.length,'fas fa-calendar-check','bg-blue-50 text-blue-600')}${statCard('Pending Bills',c+pending.reduce((s,b)=>s+parseFloat(b.total||0),0).toFixed(2),'fas fa-file-invoice-dollar','bg-amber-50 text-amber-600')}${statCard('Completed Visits',myApts.filter(a=>a.status==='completed').length,'fas fa-check-circle','bg-green-50 text-green-600')}${statCard('Lab Tests',myLabs.length,'fas fa-flask','bg-purple-50 text-purple-600',pendingLabs.length+' pending')}</div>
