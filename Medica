// ── TOAST ──
function toast(msg,type='info'){
  const c={success:'#059669',error:'#dc2626',warning:'#d97706',info:'#1d4ed8'};
  const ic={success:'fa-check-circle',error:'fa-exclamation-triangle',warning:'fa-exclamation-circle',info:'fa-info-circle'};
  const el=document.createElement('div');
  el.style.cssText=`position:fixed;top:18px;right:18px;z-index:9999;display:flex;align-items:center;gap:10px;padding:11px 18px;border-radius:12px;color:#fff;font-size:13px;font-weight:600;box-shadow:0 8px 28px rgba(0,0,0,0.22);background:${c[type]};animation:fade .3s ease;max-width:400px;word-break:break-word;`;
  el.innerHTML=`<i class="fas ${ic[type]}"></i><span>${msg}</span>`;
  document.body.appendChild(el);setTimeout(()=>{try{el.remove();}catch(e){}},4500);
}

