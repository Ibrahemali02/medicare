function ptRows(pts){
  if(!pts.length)return`<tr><td colspan="5" class="td text-center py-12 text-gray-400"><i class="fas fa-users text-4xl block mb-3"></i>No patients found</td></tr>`;
  return pts.map(p=>`<tr class="trow"><td class="td"><div class="flex items-center gap-3">${ava(p.profileImage,p.firstName)}<div><p class="font-semibold text-sm">${p.firstName} ${p.lastName}</p><p class="text-xs text-gray-400">#${p.id}</p></div></div></td><td class="td"><p class="text-xs">${p.email||''}</p><p class="text-xs text-gray-400">${p.phone||''}</p></td><td class="td"><p class="text-xs font-medium">${p.dateOfBirth||'N/A'}</p><p class="text-xs text-gray-400">${p.gender||'N/A'}</p></td><td class="td"><p class="text-xs font-bold text-red-600">${p.bloodType||'N/A'}</p><p class="text-xs text-gray-400">${p.allergies||'None'}</p></td>${['admin','doctor','receptionist'].includes(CU.role)?`<td class="td"><div class="flex gap-1 flex-wrap"><button onclick="openPtModal(${p.id})" class="btn bo bsm"><i class="fas fa-edit mr-1"></i>Edit</button>${['admin','doctor'].includes(CU.role)?`<button onclick="openRecModal(${p.id})" class="btn bp bsm"><i class="fas fa-file-medical mr-1"></i>Record</button>`:''}${['admin','receptionist'].includes(CU.role)?`<button onclick="openLabModal(${p.id})" class="btn bo bsm"><i class="fas fa-flask mr-1"></i>Lab</button>`:''}${CU.role==='admin'?`<button onclick="delPt(${p.id})" class="btn bd bsm"><i class="fas fa-trash"></i></button>`:''}</div></td>`:''}</tr>`).join('');
}

async function filterPts(){
  const t=(g('pt-q')||'').toLowerCase();
  let[pts,apts]=await Promise.all([getPatients(),getAppointments()]);
  if(CU.role==='doctor'){const ids=[...new Set(apts.filter(a=>a.doctorId===CU.id).map(a=>a.patientId))];pts=pts.filter(p=>ids.includes(p.id));}
  if(CU.role==='receptionist'&&CU.assignedDoctorId){const ids=[...new Set(apts.filter(a=>a.doctorId===CU.assignedDoctorId).map(a=>a.patientId))];pts=pts.filter(p=>ids.includes(p.id));}
  if(t)pts=pts.filter(p=>`${p.firstName} ${p.lastName}`.toLowerCase().includes(t)||(p.email||'').toLowerCase().includes(t)||(p.phone||'').includes(t));
  const pb=sel('pt-body');if(pb)pb.innerHTML=ptRows(pts);
}

