const SUPABASE_URL = "https://jlrsdawtnauynzemvguw.supabase.co";
const SUPABASE_ANON_KEY = "sb_publishable_D_KqKZkatua7n6qGPRPX5w__JBv7H4_";
const sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

const cache = {};
function snakeToCamel(o){if(Array.isArray(o))return o.map(snakeToCamel);if(o&&typeof o==='object')return Object.fromEntries(Object.entries(o).map(([k,v])=>[k.replace(/_([a-z])/g,(_,c)=>c.toUpperCase()),snakeToCamel(v)]));return o;}
function camelToSnake(o){if(Array.isArray(o))return o.map(camelToSnake);if(o&&typeof o==='object')return Object.fromEntries(Object.entries(o).map(([k,v])=>[k.replace(/([A-Z])/g,c=>'_'+c.toLowerCase()),camelToSnake(v)]));return o;}

async function dbGet(table,filters={},single=false){
  let q=sb.from(table).select('*');
  for(const[k,v]of Object.entries(filters))q=q.eq(k,v);
  if(single)q=q.single();
  const{data,error}=await q;
  if(error){console.error(table,error);return single?null:[];}
  return snakeToCamel(data);
}
async function dbInsert(table,obj){
  const{data,error}=await sb.from(table).insert(camelToSnake(obj)).select().single();
  if(error){console.error('insert',table,error);return null;}
  return snakeToCamel(data);
}
async function dbUpdate(table,id,obj){
  const{data,error}=await sb.from(table).update(camelToSnake(obj)).eq('id',id).select().single();
  if(error){console.error('update',table,error);return null;}
  return snakeToCamel(data);
}
async function dbDelete(table,id){const{error}=await sb.from(table).delete().eq('id',id);return!error;}

async function getUsers(){return cache.users||(cache.users=await dbGet('users'));}
async function getDoctors(){return cache.doctors||(cache.doctors=await dbGet('doctors'));}
async function getPatients(){return cache.patients||(cache.patients=await dbGet('patients'));}
async function getAppointments(){return cache.apts||(cache.apts=await dbGet('appointments'));}
async function getRecords(){return cache.records||(cache.records=await dbGet('records'));}
async function getLabs(){return cache.labs||(cache.labs=await dbGet('labs'));}
async function getBills(){return cache.bills||(cache.bills=await dbGet('bills'));}
async function getCfg(){
  if(cache.cfg)return cache.cfg;
  const rows=await dbGet('cfg');
  cache.cfg=(rows&&rows.length?rows[0]:{clinicName:'MediCare Pro',apptDur:30,currency:'$',notifs:true});
  return cache.cfg;
}
function clearCache(...keys){if(keys.length)keys.forEach(k=>delete cache[k]);else Object.keys(cache).forEach(k=>delete cache[k]);}
function hashPw(pw){return btoa(unescape(encodeURIComponent(pw)));}
function checkPw(stored,input){
  try{return stored===input||stored===btoa(unescape(encodeURIComponent(input)))||stored===btoa(input)||(atob(stored)===input);}catch(e){return stored===input;}
}
