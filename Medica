  clearCache('apts','bills');
  toast(`Appointment ${status}`,'success');
  loadPage(CU.role==='customer'?'my-apts':'appointments');
}

async function cancelApt(id){if(confirm('Cancel this appointment?'))await updateAptSt(id,'cancelled');}

async function delApt(id){
