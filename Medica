}

function aptCards(apts,patients,users,showActions=true){
  if(!apts.length)return`<p class="text-gray-400 text-xs text-center py-6">No appointments</p>`;
  const canManage=['admin','doctor','receptionist'].includes(CU.role);
  return apts.map(a=>{const p=patients.find(p=>p.id===a.patientId),du=users.find(u=>u.id===a.doctorId);if(!p)return'';return`<div class="flex items-center justify-between p-3 border border-gray-100 rounded-xl mb-2 hover:bg-gray-50"><div class="flex items-center gap-3">${ava(p.profileImage,p.firstName)}<div><p class="text-sm font-semibold">${p.firstName} ${p.lastName}</p><p class="text-xs text-gray-500">${fmtDate(a.appointmentDate)} · ${a.appointmentTime}${du?` · Dr. ${du.firstName} ${du.lastName}`:''}</p>${a.notes?`<p class="text-xs text-gray-400 italic">${a.notes}</p>`:''}</div></div><div class="flex items-center gap-1.5 flex-wrap justify-end">${sbadge(a.status)}${showActions&&canManage?`${!['completed','cancelled'].includes(a.status)?`<button onclick="updateAptSt(${a.id},'completed')" class="btn bs bsm"><i class="fas fa-check mr-1"></i>Done</button>`:''}${a.status==='scheduled'?`<button onclick="updateAptSt(${a.id},'confirmed')" class="btn bp bsm"><i class="fas fa-check-double mr-1"></i>Confirm</button>`:''}${!['cancelled','completed'].includes(a.status)?`<button onclick="cancelApt(${a.id})" class="btn bd bsm"><i class="fas fa-ban mr-1"></i>Cancel</button>`:''}${a.status==='cancelled'?`<button onclick="updateAptSt(${a.id},'scheduled')" class="btn bs bsm"><i class="fas fa-undo mr-1"></i>Restore</button>`:''}${CU.role==='admin'?`<button onclick="delApt(${a.id})" class="btn bd bsm"><i class="fas fa-trash"></i></button>`:''}`:''}</div></div>`;}).join('');
}

async function filterApts(){
  const qp=(g('apt-qp')||'').toLowerCase(),qd=(g('apt-qd')||'').toLowerCase(),qdate=g('apt-qdate'),qst=g('apt-qst')||'all';
  if(!qp&&!qd&&!qdate&&qst==='all'){sel('apt-search-result')?.classList.add('hidden');return;}
  const[apts,patients,users]=await Promise.all([getAppointments(),getPatients(),getUsers()]);
  let filtered=apts;
  if(CU.role==='doctor')filtered=apts.filter(a=>a.doctorId===CU.id);
  if(qp)filtered=filtered.filter(a=>{const p=patients.find(p=>p.id===a.patientId);return`${p?.firstName} ${p?.lastName}`.toLowerCase().includes(qp);});
  if(qd)filtered=filtered.filter(a=>{const du=users.find(u=>u.id===a.doctorId);return`${du?.firstName} ${du?.lastName}`.toLowerCase().includes(qd);});
  if(qdate)filtered=filtered.filter(a=>a.appointmentDate===qdate);
  if(qst!=='all')filtered=filtered.filter(a=>a.status===qst);
  const res=sel('apt-search-result'),rows=sel('apt-search-rows');
  if(res)res.classList.remove('hidden');
  if(rows)rows.innerHTML=aptCards(filtered,patients,users);
}

function clearAptFilter(){['apt-qp','apt-qd','apt-qdate'].forEach(id=>{const e=sel(id);if(e)e.value='';});const s=sel('apt-qst');if(s)s.value='all';sel('apt-search-result')?.classList.add('hidden');}

