async function monthlyBillSec(filteredBills,appointments,patients,allBills){
  const monthly={},c=cur();
  filteredBills.forEach(b=>{const d=new Date(b.date),k=`${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;if(!monthly[k])monthly[k]={count:0,paid:0,pa:0,pending:0,pea:0};monthly[k].count++;if(b.status==='paid'){monthly[k].paid++;monthly[k].pa+=parseFloat(b.total||0);}else{monthly[k].pending++;monthly[k].pea+=parseFloat(b.total||0);}});
  const data=Object.entries(monthly).map(([k,v])=>({k,...v})).sort((a,b)=>b.k.localeCompare(a.k));
  return`<div class="card p-5"><div class="flex items-center gap-2 mb-4"><i class="fas fa-chart-bar text-blue-500"></i><h2 class="font-bold text-sm">Monthly Analytics</h2></div>${data.length?`<div class="overflow-x-auto"><table class="w-full"><thead><tr><th class="th">Month</th><th class="th">Bills</th><th class="th">Paid</th><th class="th">Pending</th><th class="th">Revenue</th><th class="th">Outstanding</th></tr></thead><tbody>${data.map(m=>{const[y,mn]=m.k.split('-'),mName=new Date(y,mn-1).toLocaleDateString('en-US',{month:'short',year:'numeric'});return`<tr class="trow"><td class="td text-xs font-bold">${mName}</td><td class="td text-xs">${m.count}</td><td class="td"><span class="badge b-green">${m.paid}</span></td><td class="td"><span class="badge b-yellow">${m.pending}</span></td><td class="td text-xs font-bold text-green-700">${c}${m.pa.toFixed(2)}</td><td class="td text-xs text-amber-700">${c}${m.pea.toFixed(2)}</td></tr>`;}).join('')}</tbody></table></div>`:'<p class="text-gray-400 text-xs text-center py-6">No billing data yet</p>'}</div>`;
}

