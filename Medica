  <div class="card p-5"><div class="flex items-center gap-2 mb-4"><i class="fas fa-lock text-red-500"></i><h2 class="font-bold text-sm">Change My Password</h2></div><div class="space-y-3 max-w-sm"><div><label class="lbl">Current Password</label><input id="cp-cur" type="password" class="inp"></div><div><label class="lbl">New Password</label><input id="cp-new" type="password" class="inp"></div><div><label class="lbl">Confirm New Password</label><input id="cp-con" type="password" class="inp"></div><button onclick="changeMyPw()" class="btn bp text-xs"><i class="fas fa-key mr-1"></i>Change Password</button></div></div>
  <div class="card p-5"><div class="flex items-center justify-between mb-4"><div class="flex items-center gap-2"><i class="fas fa-users text-purple-500"></i><h2 class="font-bold text-sm">User Management</h2></div></div><div class="overflow-x-auto"><table class="w-full"><thead><tr><th class="th">User</th><th class="th">Role</th><th class="th">Email</th><th class="th">Status</th><th class="th">Actions</th></tr></thead><tbody>${users.map(u=>`<tr class="trow"><td class="td"><div class="flex items-center gap-2">${ava(u.profileImage,u.firstName)}<p class="text-xs font-semibold">${u.firstName} ${u.lastName}</p></div></td><td class="td"><span class="badge ${u.role==='admin'?'b-purple':u.role==='doctor'?'b-blue':u.role==='receptionist'?'b-teal':'b-gray'}">${u.role}</span></td><td class="td text-xs">${u.email}</td><td class="td"><span class="badge ${u.isActive?'b-green':'b-red'}">${u.isActive?'Active':'Inactive'}</span></td><td class="td"><div class="flex gap-1"><button onclick="openResetPwModal(${u.id})" class="btn bw bsm"><i class="fas fa-key mr-1"></i>Reset PW</button>${u.id!==CU.id?`<button onclick="toggleUserSt(${u.id})" class="btn ${u.isActive?'bd':'bs'} bsm">${u.isActive?'Disable':'Enable'}</button>`:'<span class="text-xs text-gray-400">(you)</span>'}</div></td></tr>`).join('')}</tbody></table></div></div>
  <div class="card p-5"><div class="flex items-center gap-2 mb-4"><i class="fas fa-clipboard-list text-gray-500"></i><h2 class="font-bold text-sm">Audit Log (Last 20)</h2></div><div class="overflow-x-auto"><table class="w-full"><thead><tr><th class="th">Time</th><th class="th">User</th><th class="th">Action</th><th class="th">Detail</th></tr></thead><tbody>${auditLog.map(l=>`<tr class="trow"><td class="td text-xs">${fmtDt(l.time)}</td><td class="td text-xs">${l.userName||''}<br><span class="text-gray-400">${l.role||''}</span></td><td class="td"><span class="badge b-blue text-xs">${l.action}</span></td><td class="td text-xs text-gray-500">${l.detail||''}</td></tr>`).join('')||'<tr><td colspan="4" class="td text-center text-gray-400 py-6">No audit entries yet</td></tr>'}</tbody></table></div></div></div>`;
